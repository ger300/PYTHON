import csv


def collect_user_info(count):
    users = []

    for i in range(1, count + 1):
        print(f"\n--- მომხმარებელი #{i} ---")

        first_name = input("სახელი: ")
        last_name = input("გვარი: ")

        while True:
            try:
                age = int(input("ასაკი: "))
                break
            except ValueError:
                print("❌ შეცდომა! ასაკი უნდა იყოს მთელი რიცხვი. სცადეთ თავიდან.")

        users.append({
            "ID": i,
            "first_name": first_name,
            "last_name": last_name,
            "age": age
        })

    with open("users.csv", "w", newline="", encoding="utf-8") as f:
        fieldnames = ["ID", "first_name", "last_name", "age"]
        writer = csv.DictWriter(f, fieldnames=fieldnames)

        writer.writeheader()
        writer.writerows(users)

    print(f"\n✅ მონაცემები შენახულია users.csv ფაილში!")


collect_user_info(3)

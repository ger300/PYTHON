import re

def word_count(sentence):
   
    sentence = sentence.lower()
    
     
    words = re.findall(r'\b\w+\b', sentence)
    
    result = {}
    
    for word in words:
        if word in result:
            result[word] += 1
        else:
            result[word] = 1
    
    return result


 
text = "This is a test. This test is fun."
print(word_count(text))

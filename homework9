def sum_numbers():
    count = int(input("რამდენი რიცხვის შეყვანა გინდა? "))
    total = 0
    
    for i in range(count):
        num = float(input(f"შეიყვანე {i+1}-ე რიცხვი: "))
        total += num
    
    return total


 
result = sum_numbers()
print("ჯამი:", result)



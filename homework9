def split_even_odd(*args):
    odd_numbers = []
    even_numbers = []
    
    for num in args:
        if num % 2 == 0:
            even_numbers.append(num)
        else:
            odd_numbers.append(num)
    
    return odd_numbers, even_numbers


 
odds, evens = split_even_odd(1, 2, 3, 4, 5, 6, 7)

print("კენტი რიცხვები:", odds)
print("ლუწი რიცხვები:", evens)

